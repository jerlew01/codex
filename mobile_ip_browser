                    elif attempt < 3:
                        logger.warning(f"Verification attempt {attempt} failed for session #{session_id}, retrying...")
                    else:
                        logger.error(f"All verification attempts failed for session #{session_id}")
                
                # 9. Return to the video site and ensure video is playing
                stored_url = session.get('current_url')
                if stored_url and stored_url != "https://ipinfo.io/json" and stored_url != "https://example.com":
