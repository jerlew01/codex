def is_same_carrier(ip1, ip2):
    """Check if IPs are from the same carrier network blocks"""
    if not ip1 or not ip2:
        return False
    # T-Mobile IPs typically start with 172.56.x.x or 172.58.x.x
    parts1 = ip1.split('.')
    parts2 = ip2.split('.')
    return (len(parts1) >= 2 and len(parts2) >= 2 and 
           parts1[0] == parts2[0] == '172' and 
           (parts1[1] in ['56', '58'] and parts2[1] in ['56', '58']))

