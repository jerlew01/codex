        import traceback
        logger.error(traceback.format_exc())
        return None

def stop_identity_proxy(port):
    """Stop a proxy server"""
    if port in active_proxies:
        try:
            proxy_info = active_proxies[port]
            server = proxy_info['server']
            identity_ip = proxy_info['ip']
            
            # Shutdown the server
            server.shutdown()
            server.server_close()
            
            # Remove from active proxies
            del active_proxies[port]
            
            logger.info(f"Stopped proxy for IP {identity_ip} on port {port}")
            return True
            
        except Exception as e:
            logger.error(f"Error stopping proxy on port {port}: {e}")
    
    return False

