def verify_session_identity(session_id):
    """Verify if the session's IP identity is correctly enforced with enhanced error handling"""
    global known_ips
    
    if session_id not in active_sessions:
        logger.error(f"Session #{session_id} not found")
        return False
    
    session = active_sessions[session_id]
    driver = session['driver']
    expected_ip = session['ip']
    
    # Store the current URL before navigating away - safely
    try:
        current_url = driver.current_url
        if current_url and current_url != "https://ipinfo.io/json" and current_url != "https://example.com":
            session['current_url'] = current_url
    except Exception as e:
        logger.warning(f"Error storing current URL: {e}")
    
    # First check if browser is still responsive
    try:
        driver.execute_script("return navigator.userAgent")
    except Exception as e:
        logger.error(f"Browser for session #{session_id} not responsive: {e}")
        session['verified'] = False
        return False
    
    try:
        # Re-apply CDP proxy settings before checking
        try:
            # Set proxy via CDP (this is more effective than JavaScript)
            proxy_config = {
                'mode': 'fixed_servers',
                'server': f'127.0.0.1:{session["port"]}'
            }
            driver.execute_cdp_cmd('Network.setProxySettings', {'proxyConfig': proxy_config})
            
            # Re-apply identity headers
            driver.execute_cdp_cmd('Network.setExtraHTTPHeaders', {
                "headers": {
                    "X-Forwarded-For": expected_ip,
                    "CF-Connecting-IP": expected_ip,
                    "X-Real-IP": expected_ip,
                    "True-Client-IP": expected_ip,
                    "X-Client-IP": expected_ip
                }
            })
            logger.debug(f"Re-applied proxy and headers via CDP for session #{session_id}")
        except Exception as e:
            logger.warning(f"Failed to apply proxy via CDP before verification: {e}")
        
        # Try a simpler verification approach to reduce crashes
        verification_services = [
            "https://ipinfo.io/json",
            "https://api.ipify.org?format=json"
        ]
        
        successful_verifications = 0
        reported_ips = []
        
        # Only try one service at a time to reduce chances of crashes
        for service in verification_services:
            try:
                logger.info(f"Checking IP with {service}")
                
                # Use a try-except for each navigation
                try:
                    driver.get(service)
                    time.sleep(3)
                    active_sessions[session_id]['stats']['pages_loaded'] += 1
                except TimeoutException:
                    logger.warning(f"Timeout loading {service}, skipping")
                    continue
                except WebDriverException as e:
                    if "tab crashed" in str(e):
                        logger.error(f"Browser tab crashed during verification. Marking as failed.")
                        session['verified'] = False
                        # Don't return yet - record the error but try to recover
                    else:
                        logger.error(f"WebDriver error: {e}")
                        continue
                
                # Check if browser is still responsive after navigation
                try:
                    driver.execute_script("return navigator.userAgent")
                except Exception as e:
                    logger.error(f"Browser no longer responsive after loading {service}: {e}")
                    break
                
                # Extract the reported IP based on the service - with safe error handling
                reported_ip = "Unknown"
                try:
                    if "ipinfo.io" in service:
                        body_text = driver.find_element(By.TAG_NAME, "pre").text
                        data = json.loads(body_text)
                        reported_ip = data.get("ip", "Unknown")
                    elif "api.ipify.org" in service:
                        body_text = driver.find_element(By.TAG_NAME, "pre").text
                        data = json.loads(body_text)
                        reported_ip = data.get("ip", "Unknown")
                    else:
                        # Default handler for other services - look for pre tag with JSON
                        body_text = driver.find_element(By.TAG_NAME, "pre").text
                        try:
                            data = json.loads(body_text)
                            reported_ip = data.get("ip", "Unknown")
                        except:
                            # If not JSON, just use the text if it looks like an IP
                            if re.match(r"\d+\.\d+\.\d+\.\d+", body_text.strip()):
                                reported_ip = body_text.strip()
                except Exception as e:
                    logger.error(f"Error parsing response from {service}: {e}")
                    continue
                
                reported_ips.append(reported_ip)
                logger.info(f"Session #{session_id} - {service} reports IP: {reported_ip}")
                
                # Check if the reported IP matches expected or is in the same carrier network
                if reported_ip == expected_ip:
                    successful_verifications += 1
                    logger.info(f"[PERFECT] {service} shows expected IP: {expected_ip}")
                elif is_same_carrier(reported_ip, expected_ip):
                    successful_verifications += 1
                    logger.info(f"[GOOD] {service} shows same carrier network: {reported_ip}")
                else:
                    logger.warning(f"[FAIL] {service} verification failed - IP mismatch")
                    logger.warning(f"  Expected: {expected_ip}")
                    logger.warning(f"  Actual: {reported_ip}")
                
                # Add reported IP to known IPs collection
                if reported_ip and reported_ip != "Unknown":
                    known_ips.add(reported_ip)
                    
                # Stop after first successful verification to minimize browser stress
                if successful_verifications > 0:
                    break
                    
            except Exception as e:
                logger.error(f"Error checking {service} for session #{session_id}: {e}")
                
        # Determine primary reported IP (use most common)
        primary_reported_ip = "Unknown"
        if reported_ips:
            from collections import Counter
            counter = Counter(reported_ips)
            primary_reported_ip = counter.most_common(1)[0][0]
            
            # Store the result for future reference
            session['reported_ip'] = primary_reported_ip
            session['last_verified'] = time.time()
        
        # Try to return to the stored URL if available - safely
        try:
            stored_url = session.get('current_url')
            if stored_url and stored_url != "https://ipinfo.io/json" and stored_url not in verification_services:
                logger.info(f"Returning session #{session_id} to {stored_url}")
                driver.get(stored_url)
                
                # Let the page load before trying to play video
                time.sleep(3)
                
                # Try to restart video playback - with safer approach
                if 'session_manager' in session and any(site in stored_url.lower() for site in ['youtube.com', 'twitch.tv', 'kick.com']):
                    try:
                        if 'youtube.com' in stored_url.lower():
                            session['session_manager'].handle_youtube_playback()
                        elif 'twitch.tv' in stored_url.lower():
                            session['session_manager'].handle_twitch_playback()
                        elif 'kick.com' in stored_url.lower():
                            session['session_manager'].handle_kick_playback()
                        else:
                            session['session_manager'].handle_generic_playback()
                    except Exception as e:
                        logger.error(f"Error restarting playback: {e}")
        except Exception as e:
            logger.warning(f"Error returning to previous URL: {e}")
        
        # Determine verification success
        if successful_verifications >= 1:
            session['verified'] = True
            session['primary_verification_service'] = verification_services[0]
            logger.info(f"[SUCCESS] Session #{session_id} identity verified")
            return True
        else:
            session['verified'] = False
            logger.warning(f"[FAIL] Session #{session_id} identity verification failed")
            if primary_reported_ip != "Unknown":
                logger.warning(f"  Expected: {expected_ip}")
                logger.warning(f"  Reported: {primary_reported_ip}")
            return False
            
    except Exception as e:
        logger.error(f"General error in verification process for session #{session_id}: {e}")
        session['verified'] = False
        return False

def recover_crashed_session(session_id):
    """Attempt to recover a crashed session"""
    if session_id not in active_sessions:
        logger.error(f"Session #{session_id} not found")
        return False
    
    session = active_sessions[session_id]
    
    try:
        # First check if browser is responsive
        try:
            driver = session['driver']
            driver.execute_script("return navigator.userAgent")
            logger.info(f"Session #{session_id} is still responsive, no recovery needed")
            return True
        except Exception as e:
            logger.warning(f"Session #{session_id} crashed or not responsive: {e}")
            
        # Try to close the crashed browser
        try:
            driver = session['driver']
            driver.quit()
        except:
            pass
        
        # Get the key session info we need to recreate it
        ip = session['ip']
        proxy_port = session.get('port')
        dns_port = session.get('dns_port')
        profile_dir = session.get('profile_dir')
        stored_url = session.get('current_url')
        use_incognito = session.get('incognito', False)
        
        logger.info(f"Attempting to recover session #{session_id} for IP {ip}")
        
        # Setup browser options
        options = uc.ChromeOptions()
        options.add_argument(f"--user-data-dir={profile_dir}")
        options.add_argument(f'--proxy-server=127.0.0.1:{proxy_port}')
        
        if use_incognito:
            options.add_argument("--incognito")
        
        # Add stability options
        options.add_argument("--no-sandbox")
        options.add_argument("--disable-gpu")
        options.add_argument("--disable-dev-shm-usage")
        options.add_argument("--disable-web-security")
        options.add_argument("--disable-site-isolation-trials")
        
        # Set timeout for page loads
        uc_params = {
            "page_load_strategy": "eager",
            "use_subprocess": True,
        }
        
        # Create a new browser with retries
        try:
            new_driver = create_browser_with_retries(options, uc_params)
            if not new_driver:
                logger.error(f"Failed to create new browser for crashed session #{session_id}")
                return False
                
            # Update session with new driver
            active_sessions[session_id]['driver'] = new_driver
            
            # Reapply IP enforcement
            if 'ip_enforcer' in session:
                try:
                    enforcer = session['ip_enforcer']
                    enforcer.install_in_browser(new_driver)
                    logger.info(f"Reapplied IP enforcement for recovered session #{session_id}")
                except Exception as e:
                    logger.warning(f"Failed to reapply IP enforcement: {e}")
                    
                    # Create a new enforcer if needed
                    try:
                        new_enforcer = AggressiveIPEnforcer(ip)
                        new_enforcer.install_in_browser(new_driver)
                        active_sessions[session_id]['ip_enforcer'] = new_enforcer
                    except Exception as e2:
                        logger.error(f"Failed to create new enforcer: {e2}")
            
            # Create new session manager
            try:
                session_manager = SessionManager(new_driver, session_id)
                active_sessions[session_id]['session_manager'] = session_manager
                monitor_thread = session_manager.start_monitoring()
                active_sessions[session_id]['monitor_thread'] = monitor_thread
            except Exception as e:
                logger.error(f"Failed to create session manager: {e}")
            
            # Navigate back to stored URL if available
            if stored_url:
                try:
                    new_driver.get(stored_url)
                    active_sessions[session_id]['stats']['pages_loaded'] += 1
                    logger.info(f"Returned recovered session to {stored_url}")
                    
                    # Apply playback handler if needed
                    if 'session_manager' in active_sessions[session_id]:
                        try:
                            if 'youtube.com' in stored_url.lower():
                                active_sessions[session_id]['session_manager'].handle_youtube_playback()
                            elif 'twitch.tv' in stored_url.lower():
                                active_sessions[session_id]['session_manager'].handle_twitch_playback()
                            elif 'kick.com' in stored_url.lower():
                                active_sessions[session_id]['session_manager'].handle_kick_playback()
                        except Exception as e:
                            logger.error(f"Failed to restart playback: {e}")
                except Exception as e:
                    logger.error(f"Failed to navigate to stored URL: {e}")
            
            # Mark recovery successful
            logger.info(f"Successfully recovered session #{session_id}")
            return True
            
        except Exception as e:
            logger.error(f"Failed to recover session #{session_id}: {e}")
            return False
    
    except Exception as e:
        logger.error(f"Error in recovery process for session #{session_id}: {e}")
        return False

def close_session(session_id):
    """Close a browser session and clean up resources"""
    if session_id not in active_sessions:
        logger.warning(f"Session #{session_id} not found")
        return False
    
    try:
        session = active_sessions[session_id]
        driver = session['driver']
        proxy_port = session['port']
        dns_port = session.get('dns_port')
        ip = session['ip']
        
        # Remove any custom routes we added for this session
        if 'routes' in session:
            for route in session['routes']:
                try:
                    delete_route(route)
                    logger.info(f"Deleted custom route for session #{session_id}")
                except Exception as e:
                    logger.warning(f"Failed to delete route: {e}")
        
        # Stop packet spoofing if active
        if 'spoof_thread' in session and session['spoof_thread'].is_alive():
            logger.info(f"Stopping packet spoofing for session #{session_id}")
            # We can't directly stop the thread, but we can set a flag to indicate it should stop
            if 'spoof_manager' in session:
                session['spoof_manager'].is_running = False
        
        # Stop session monitoring if active
        if 'session_manager' in session:
            logger.info(f"Stopping session monitoring for session #{session_id}")
            session['session_manager'].is_active = False
        
        # Take final screenshot
        try:
            take_screenshot(session_id, f"final_{session_id}_{int(time.time())}.png")
        except:
            pass
        
        # Close any ForceBindIP process if it exists
        if 'forcebindip_process' in session and session['forcebindip_process']:
            try:
                session['forcebindip_process'].terminate()
                logger.info(f"Terminated ForceBindIP process for session #{session_id}")
            except Exception as e:
                logger.warning(f"Error terminating ForceBindIP process: {e}")
            
        # Close the browser
        driver.quit()
        
        # Check if any other sessions are using this proxy
        other_sessions_using_proxy = False
        for other_id, other_session in active_sessions.items():
            if other_id != session_id and other_session['port'] == proxy_port:
                other_sessions_using_proxy = True
                break
        
        # If no other sessions are using this proxy, stop it
        if not other_sessions_using_proxy:
            stop_identity_proxy(proxy_port)
        
        # Check if any other sessions are using this DNS server
        if dns_port:
            other_sessions_using_dns = False
            for other_id, other_session in active_sessions.items():
                if other_id != session_id and other_session.get('dns_port') == dns_port:
                    other_sessions_using_dns = True
                    break
            
            # If no other sessions are using this DNS server, stop it
            if not other_sessions_using_dns:
                stop_identity_dns(dns_port)
        
        # Store session info if it failed verification
        if not session.get('verified', False):
            dropped_sessions[ip] = "Failed verification"
        
        # Remove from active sessions
        del active_sessions[session_id]
        
        logger.info(f"Closed session #{session_id}")
        return True
    
    except Exception as e:
        logger.error(f"Error closing session #{session_id}: {e}")
        return False


def close_all_sessions():
    """Close all browser sessions and clean up resources"""
    logger.info("Closing all sessions...")
    
    # Close all browser sessions
    for session_id in list(active_sessions.keys()):
        close_session(session_id)
    
    # Stop any remaining proxies and DNS servers
    stop_all_proxies_and_dns()
    
    logger.info("All sessions closed")

