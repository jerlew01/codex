def monitor_network_changes():
    """Monitor for network changes and adapt as needed"""
    last_ip = get_current_ip()
    logger.info(f"Network monitoring started with initial IP: {last_ip}")
    
    while True:
        try:
            time.sleep(30)  # Check every 30 seconds
            current_ip = get_current_ip()
            
            if current_ip and last_ip and current_ip != last_ip:
                logger.info(f"Network change detected: {last_ip} -> {current_ip}")
                
                # First, add to known IPs
                global known_ips
                known_ips.add(current_ip)
                
                # Then handle the change
                handle_network_change()
                
                # Create a new session for this IP if automatic creation is enabled
                if AUTO_CREATE_SESSIONS:
                    logger.info(f"Auto-creating new session for IP {current_ip}")
                    try:
                        session_id = create_browser_session(current_ip)
                        if session_id:
                            logger.info(f"Successfully created new auto-session #{session_id} for IP {current_ip}")
                        else:
                            logger.error(f"Failed to auto-create session for IP {current_ip}")
                    except Exception as e:
                        logger.error(f"Error auto-creating session for new IP {current_ip}: {e}")
                
                last_ip = current_ip
        except Exception as e:
            logger.error(f"Error in network monitoring: {e}")

def start_monitoring_threads():
    """Start all monitoring threads"""
    threads = []
    
    monitoring_functions = [
        (log_sessions_status, "StatusThread"),
        (keep_sessions_alive, "KeepAliveThread"),
        (recheck_session_identities, "IdentityCheckThread"),
        (monitor_network_stats, "StatsThread"),
        (monitor_network_changes, "NetworkMonitorThread")
    ]
    
    for func, name in monitoring_functions:
        thread = threading.Thread(target=func, name=name, daemon=True)
        thread.start()
        threads.append(thread)
        logger.info(f"Started monitoring thread: {name}")
    
    return threads

