                # 7. Wait for changes to take effect (critical)
                time.sleep(2)
                
                # 8. Verify the session to ensure it's working with progressive checks
                for attempt in range(1, 4):
                    logger.info(f"Verification attempt {attempt} for session #{session_id}")
                    time.sleep(attempt * 2)  # Progressively longer waits
                    
                    if verify_session_identity(session_id):
                        logger.info(f"Session #{session_id} successfully verified after network change")
