def get_current_ip():
    """
    Get the current public IP address with enhanced reliability
    """
    ip_services = [
        "https://api.ipify.org?format=text",
        "https://ifconfig.me/ip",
        "https://icanhazip.com/",
        "https://ipinfo.io/ip",
        "https://checkip.amazonaws.com"
    ]
    
    # First try a direct request to each service
    for service in ip_services:
        try:
            logger.debug(f"Checking IP using {service}...")
            response = requests.get(
                service,
                timeout=3,  # Shorter timeout
                proxies=REQUEST_PROXIES,
                headers={
                    "User-Agent": "Mozilla/5.0",
                    "Cache-Control": "no-cache, no-store, must-revalidate"
                }
            )
            
            if response.status_code == 200:
                ip = response.text.strip()
                if ip and len(ip.split('.')) == 4:  # Basic IP validation
                    logger.debug(f"Detected IP: {ip} via {service}")
                    return ip
        except Exception as e:
            logger.debug(f"Failed to get IP from {service}: {e}")
    
    # If all fails, try socket connection as a fallback
    try:
        s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
        s.connect(("8.8.8.8", 80))
        ip = s.getsockname()[0]
        s.close()
        logger.debug(f"Detected local IP: {ip} via socket connection")
        return ip
    except Exception as e:
        logger.debug(f"Socket IP detection failed: {e}")
    
    logger.error("Failed to detect IP from all services")
    return None

