            logger.info(f"Dropped sessions: {len(dropped_sessions)}")
            
            # Count verified vs unverified sessions
            verified = 0
            unverified = 0
            
            for session_id, session in active_sessions.items():
                if session.get('verified', False):
                    verified += 1
                else:
                    unverified += 1
                
                # Log details for each session
                expected_ip = session.get('ip', 'Unknown')
