def recheck_session_identities():
    """Periodically recheck if sessions maintain their IP identity"""
    while True:
        time.sleep(300)  # Every 5 minutes
        
        with session_lock:
            for session_id in list(active_sessions.keys()):
                try:
                    # Only verify sessions that haven't been verified in the last 2 minutes
                    last_verified = time.time() - active_sessions[session_id].get('last_verified', 0)
                    if last_verified > 120:  # 2 minutes in seconds
                        logger.info(f"Rechecking identity for session #{session_id} (last checked {last_verified:.1f}s ago)")
                        
                        # CRITICAL: Re-apply enforcement before checking
                        session = active_sessions[session_id]
                        expected_ip = session['ip']
                        driver = session['driver']
                        
                        if session.get('enforce_automatically', True):
                            # Re-apply IP enforcement
                            if 'ip_enforcer' in session:
                                try:
                                    enforcer = session['ip_enforcer']
                                    enforcer.install_in_browser(driver)
                                    logger.info(f"Auto-renewed IP enforcement for session #{session_id}")
                                except Exception as e:
                                    logger.warning(f"Error auto-renewing IP enforcement: {e}")
                            else:
                                # If no enforcer exists, create one
                                try:
                                    enforcer = AggressiveIPEnforcer(expected_ip)
                                    enforcer.install_in_browser(driver)
                                    session['ip_enforcer'] = enforcer
                                    logger.info(f"Auto-added IP enforcement for session #{session_id}")
                                except Exception as e:
                                    logger.warning(f"Error auto-creating new enforcer: {e}")
                            
                            # Also apply CDP headers directly
                            try:
                                driver.execute_cdp_cmd('Network.enable', {})
                                driver.execute_cdp_cmd('Network.setExtraHTTPHeaders', {
                                    "headers": {
                                        "X-Forwarded-For": expected_ip,
                                        "CF-Connecting-IP": expected_ip,
                                        "X-Real-IP": expected_ip,
                                        "True-Client-IP": expected_ip,
                                        "X-Client-IP": expected_ip,
                                        "X-T-Mobile-IP": expected_ip,
                                        "X-Carrier-IP": expected_ip,
                                        "Mobile-Gateway": expected_ip,
                                        "X-Mobile-IP": expected_ip
                                    }
                                })
                            except Exception as e:
                                logger.warning(f"Failed to apply CDP headers during auto-enforcement: {e}")
                                
                            # Re-apply proxy settings via CDP
                            try:
                                proxy_config = {
                                    'mode': 'fixed_servers',
                                    'server': f'127.0.0.1:{session["port"]}'
                                }
                                driver.execute_cdp_cmd('Network.setProxySettings', {'proxyConfig': proxy_config})
                            except Exception as e:
                                logger.warning(f"Failed to re-apply proxy via CDP: {e}")
                        
                        # Now verify identity
                        verify_session_identity(session_id)
                except Exception as e:
                    logger.error(f"Error rechecking identity for session #{session_id}: {e}")


