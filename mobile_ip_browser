    def turn_on_and_connect_wifi(self):
        """Turn on the Wi-Fi adapter and connect to the specified Wi-Fi network."""
        if not WIFI_CONTROL_AVAILABLE:
            logger.warning("WiFi control not available - pywifi module not found")
            return False
            
        wifi = pywifi.PyWiFi()
        iface = wifi.interfaces()[0]  # Default to the first interface

        # Disconnect if already connected
        if iface.status() in [const.IFACE_CONNECTED, const.IFACE_CONNECTING]:
            iface.disconnect()
            time.sleep(1)

        # Set up the Wi-Fi profile
        profile = pywifi.Profile()
        profile.ssid = self.ssid
        profile.auth = const.AUTH_ALG_OPEN
        profile.akm.append(const.AKM_TYPE_WPA2PSK)
        profile.cipher = const.CIPHER_TYPE_CCMP
        profile.key = self.password

        # Remove existing profiles and apply the new one
        iface.remove_all_network_profiles()
        iface.add_network_profile(profile)

        # Connect to the Wi-Fi
        iface.connect(profile)
        logger.info("Attempting to connect to Wi-Fi...")

        # Wait for the connection
        for _ in range(10):  # Try for up to 10 seconds
            if iface.status() == const.IFACE_CONNECTED:
                logger.info("Successfully connected to Wi-Fi.")
                return True
            time.sleep(1)

        raise Exception("Could not connect to Wi-Fi.")
        
    def monitor_ip_changes(self, callback=None):
        """
        Monitor for IP changes and call the callback function when an IP change is detected.
        The callback function should accept the new IP as a parameter.
        """
        last_ip = self.current_ip
        consecutive_failures = 0
        MAX_FAILURES = 5
        
        logger.info(f"Starting IP change monitoring")
        logger.info(f"Current IP: {last_ip}")
        
        while True:
            try:
                current_ip = self.check_current_ip()
                
                if current_ip:
                    consecutive_failures = 0  # Reset failure counter
                    
                    if current_ip != last_ip:
                        logger.info(f"IP change detected: {last_ip} -> {current_ip}")
                        
                        # Add to known IPs set
                        global known_ips
                        known_ips.add(current_ip)
                        
                        # Update our internal current IP
                        self.current_ip = current_ip
                        
                        # Call the callback if provided
                        if callback and callable(callback):
                            try:
                                callback(current_ip)
                            except Exception as e:
                                logger.error(f"Error in IP change callback: {e}")
                                
                        last_ip = current_ip
                    else:
                        logger.debug(f"IP check: No change ({current_ip})")
                else:
                    consecutive_failures += 1
                    logger.warning(f"Failed to get IP (attempt {consecutive_failures})")
                    
                    if consecutive_failures >= MAX_FAILURES:
                        logger.error(f"Multiple IP check failures ({consecutive_failures})")
                        consecutive_failures = 0  # Reset counter
            
            except Exception as e:
                logger.error(f"Error monitoring IP changes: {e}")
            
            # Wait before next check (random delay between 5-15 seconds)
            time.sleep(random.uniform(5, 15))
    
