# Start a proxy server for a specific IP identity
def start_identity_proxy(identity_ip, tether_interface=None, tether_ip=None):
    """Start a proxy server for a specific IP identity"""
    global PROXY_PORT_START
    
    # Check if we already have a proxy for this IP
    for port, info in active_proxies.items():
        if info['ip'] == identity_ip:
            logger.info(f"Using existing proxy for IP {identity_ip} on port {port}")
            return port
    
    # Use a single fixed port unless PROXY_DYNAMIC_PORTS is enabled
    max_attempts = 5 if PROXY_DYNAMIC_PORTS else 1
    for attempt in range(1, max_attempts + 1):
        port = PROXY_PORT_START
        if PROXY_DYNAMIC_PORTS:
            PROXY_PORT_START += 1
        
        logger.info(f"Attempt {attempt}: Starting proxy on port {port} for IP {identity_ip}")
        
        try:
            # Check if the port is already in use
            sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            result = sock.connect_ex(('127.0.0.1', port))
            sock.close()
            
            if result == 0:
                if PROXY_DYNAMIC_PORTS:
                    logger.warning(f"Port {port} is already in use, trying another port")
                    continue
                else:
                    logger.error(f"Port {port} is already in use")
                    return None
            
            # Create a proxy server that binds outgoing connections to tethering interface if available
            server = IPIdentityProxyServer(('127.0.0.1', port), IPIdentityProxyHandler, identity_ip, tether_interface)
            
            # Start the proxy server in a separate thread
            proxy_thread = threading.Thread(target=server.serve_forever, daemon=True)
            proxy_thread.start()
            
            # Store proxy information
            active_proxies[port] = {
                'server': server,
                'thread': proxy_thread,
                'ip': identity_ip,
                'start_time': time.time(),
                'tether_interface': tether_interface,
                'tether_ip': tether_ip
            }
            
            logger.info(f"Successfully started proxy for IP {identity_ip} on port {port}")
            if tether_interface:
                logger.info(f"Proxy will route through tethering interface {tether_interface}")
            return port
            
        except Exception as e:
            logger.error(f"Error starting proxy on port {port} for IP {identity_ip}: {e}")
            import traceback
            logger.error(traceback.format_exc())
    
    logger.error(f"Failed to start proxy for IP {identity_ip} after multiple attempts")
    return None

# Start a DNS server for IP identity preservation
