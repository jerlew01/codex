def get_tethering_interface_info():
    """Detect the USB tethering interface and its gateway"""
    if not sys.platform == 'win32':
        return None, None, None
        
    try:
        # Get active connections
        output = subprocess.check_output(
            ["netsh", "interface", "ipv4", "show", "addresses"], 
            text=True
        )
        
        tether_interface = None
        tether_ip = None
        
        # Look for interface that might be a USB tether (NDIS or Remote, has IP in 192.168.x.x)
        for line in output.splitlines():
            if "192.168." in line or "172.20." in line:
                # Check previous lines for interface name
                for i in range(max(0, output.splitlines().index(line)-5), output.splitlines().index(line)):
                    check_line = output.splitlines()[i]
                    if "Interface" in check_line and "Configuration for" in check_line:
                        interface_name = check_line.split('"')[1]
                        if "NDIS" in interface_name or "Remote" in interface_name or "Android" in interface_name:
                            tether_interface = interface_name
                            break
            
            # Get IP address if we found the interface
            if tether_interface and "IP Address" in line:
                tether_ip = line.split(':')[-1].strip()
                break
        
        if tether_interface and tether_ip:
            # Get default gateway for this interface
            output = subprocess.check_output(
                ["netsh", "interface", "ipv4", "show", "route"], 
                text=True
            )
            
            tether_gateway = None
            for line in output.splitlines():
                if tether_interface in line and "0.0.0.0/0" in line:
                    parts = line.split()
                    for i, part in enumerate(parts):
                        if part == "NextHop":
                            # Gateway is likely in the next column
                            if i+1 < len(parts):
                                tether_gateway = parts[i+1]
                                break
                    if tether_gateway:
                        break
            
            if not tether_gateway:
                # If we can't find the gateway, guess it (common for tethering is .1)
                ip_parts = tether_ip.split('.')
                tether_gateway = f"{ip_parts[0]}.{ip_parts[1]}.{ip_parts[2]}.1"
                logger.warning(f"Could not find tethering gateway, guessing: {tether_gateway}")
                
            logger.info(f"Detected tethering interface: {tether_interface}, IP: {tether_ip}, Gateway: {tether_gateway}")
            return tether_interface, tether_ip, tether_gateway
    except Exception as e:
        logger.error(f"Error detecting tethering interface: {e}")
    
    return None, None, None

def force_interface_for_ip(target_ip, interface_ip):
    """Force traffic to a specific IP to go through a specific interface"""
    if not sys.platform == 'win32' or not WINDOWS_ROUTING_AVAILABLE:
        logger.warning("Interface forcing only supported on Windows")
        return False
        
    try:
        # Get interface information
        interface_name = get_interface_by_ip(interface_ip)
        if not interface_name:
            logger.error(f"Could not find interface with IP {interface_ip}")
            return False
            
        interface_index = get_interface_index(interface_name)
        if not interface_index:
            logger.error(f"Could not get index for interface {interface_name}")
            return False
        
        # Get the gateway for this interface
        _, _, gateway = get_tethering_interface_info()
        if not gateway:
            logger.error("Could not determine gateway for tethering interface")
            return False
        
        # Add a specific route for the target IP
        route_entry = add_route_to_interface(f"{target_ip}/32", interface_index, gateway, metric=1)
        if route_entry:
            logger.info(f"Successfully forced traffic to {target_ip} through interface {interface_name}")
            return route_entry
        else:
            logger.error(f"Failed to force traffic to {target_ip}")
            return False
    except Exception as e:
        logger.error(f"Error forcing interface: {e}")
        return False


# DNS Identity Preservation Layer
class DNSIdentityServer:
    """DNS server that preserves carrier identity by routing through carrier-specific DNS servers"""
    
    def __init__(self, carrier_ip, listen_port=None):
        if not DNS_LIB_AVAILABLE:
            raise ImportError("dnslib is required for DNSIdentityServer")
            
        self.carrier_ip = carrier_ip
        self.port = listen_port or self._get_available_port()
        self.cache = {}  # Domain -> IP mapping
        self.carrier_dns = self._detect_carrier_dns(carrier_ip)
        self.socket = None
        self.running = False
        self.thread = None
        self.stats = {
            'requests': 0,
            'cache_hits': 0,
            'carrier_lookups': 0,
            'fallbacks': 0,
            'errors': 0,
            'start_time': time.time()
        }
        
    def _get_available_port(self):
        """Find an available port for DNS server"""
        global DNS_PORT_START
        
        # Try up to 10 ports
        for _ in range(10):
            port = DNS_PORT_START
            DNS_PORT_START += 1
            
            try:
                # Check if port is in use
                sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                sock.bind(('127.0.0.1', port))
                sock.close()
                return port
            except:
                continue
                
        # If all ports failed, use a random high port
        return random.randint(20000, 65000)
        
    def _detect_carrier_dns(self, ip):
        """Determine appropriate DNS servers based on carrier IP"""
        # T-Mobile detection (common IP ranges)
        if ip.startswith('172.56') or ip.startswith('172.58'):
            return ['208.54.74.2', '208.54.75.2']  # T-Mobile DNS servers
        # Verizon detection
        elif ip.startswith('174.') or ip.startswith('70.'):
            return ['198.224.186.135', '198.224.187.135']  # Verizon DNS
        # AT&T detection
        elif ip.startswith('104.') or ip.startswith('107.'):
            return ['68.94.156.1', '68.94.157.1']  # AT&T DNS
        # Sprint detection
        elif ip.startswith('68.') or ip.startswith('166.'):
            return ['68.28.31.55', '68.28.31.53']  # Sprint DNS
        
        # If we can't determine the carrier, use Google DNS as fallback
        return ['8.8.8.8', '8.8.4.4']  # Default to Google DNS
        
    def start(self):
        """Start the DNS Identity Server"""
        if not DNS_LIB_AVAILABLE:
            logger.error("Cannot start DNS server: dnslib not available")
            return None
            
        try:
            self.socket = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
            self.socket.bind(('127.0.0.1', self.port))
            self.running = True
            
            # Start processing DNS requests in a background thread
            self.thread = threading.Thread(
                target=self._process_requests, 
                name=f"DNS_Server_{self.port}",
                daemon=True
            )
            self.thread.start()
            
            logger.info(f"DNS Identity Server started on port {self.port} for IP {self.carrier_ip}")
            logger.info(f"Using carrier DNS servers: {', '.join(self.carrier_dns)}")
            return self.port
        except Exception as e:
            logger.error(f"Failed to start DNS Identity Server: {e}")
            return None
        
    def _process_requests(self):
        """Process incoming DNS requests"""
        while self.running:
            try:
                data, addr = self.socket.recvfrom(1024)
                self.stats['requests'] += 1
                
                # Process the request asynchronously
                threading.Thread(
                    target=self._handle_dns_request, 
                    args=(data, addr), 
                    daemon=True
                ).start()
            except Exception as e:
                if self.running:  # Only log if still running (not shutdown)
                    logger.error(f"DNS request processing error: {e}")
                    self.stats['errors'] += 1
                
    def _handle_dns_request(self, data, addr):
        """Handle a single DNS request"""
        try:
            # Parse the DNS request
            request = DNSRecord.parse(data)
            qname = str(request.q.qname).rstrip('.')
            qtype = request.q.qtype
            
            # Create a response with the same ID
            response = DNSRecord(header=request.header)
            response.add_question(request.q)
            
            # Check cache first
            cache_key = f"{qname}:{qtype}"
            if cache_key in self.cache and time.time() < self.cache[cache_key]['expires']:
                # Use cached result
                cached_data = self.cache[cache_key]
                if qtype == QTYPE.A or qtype == 1:  # IPv4 address
                    response.add_answer(RR(qname, QTYPE.A, rdata=A(cached_data['ip']), ttl=cached_data['ttl']))
                elif qtype == QTYPE.AAAA or qtype == 28:  # IPv6 address
                    response.add_answer(RR(qname, QTYPE.AAAA, rdata=AAAA(cached_data['ip']), ttl=cached_data['ttl']))
                
                self.socket.sendto(response.pack(), addr)
                self.stats['cache_hits'] += 1
                return
            
            # Resolve using carrier DNS
            try:
                # Resolve through normal DNS but add carrier headers
                resolver = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
                
                try:
                    # Send to carrier DNS server
                    carrier_dns = self.carrier_dns[0]
                    resolver.sendto(data, (carrier_dns, 53))
                    resolver.settimeout(2)  # Set timeout for response
                    carrier_response, _ = resolver.recvfrom(1024)
                    
                    # Send the carrier's response back to the client
                    self.socket.sendto(carrier_response, addr)
                    self.stats['carrier_lookups'] += 1
                    
                    # Cache the result
                    try:
                        carrier_record = DNSRecord.parse(carrier_response)
                        for answer in carrier_record.rr:
                            if answer.rtype in (QTYPE.A, QTYPE.AAAA):
                                ttl = answer.ttl or 300  # Default 5 min TTL if none specified
                                self.cache[cache_key] = {
                                    'ip': str(answer.rdata),
                                    'ttl': ttl, 
                                    'expires': time.time() + ttl
                                }
                                break
                    except:
                        # Failed to parse or cache, but we already sent the response
                        pass
                        
                    # We're done, carrier DNS resolved it
                    return
                    
                except socket.timeout:
                    # Carrier DNS timed out, fall back to regular resolution
                    logger.debug(f"Carrier DNS timed out for {qname}, using fallback")
                except Exception as e:
                    logger.debug(f"Carrier DNS error for {qname}: {e}, using fallback")
                finally:
                    resolver.close()
            except Exception as e:
                logger.error(f"Error resolving through carrier DNS: {e}")
            
            # Fallback to regular DNS if carrier DNS failed
            try:
                # Get IP address
                fallback_ip = socket.gethostbyname(qname)
                
                # Add to response
                response.add_answer(RR(qname, QTYPE.A, rdata=A(fallback_ip), ttl=300))
                
                # Send response
                self.socket.sendto(response.pack(), addr)
                
                # Cache the result with a 5-minute TTL
                self.cache[cache_key] = {
                    'ip': fallback_ip,
                    'ttl': 300,
                    'expires': time.time() + 300
                }
                
                self.stats['fallbacks'] += 1
                
            except Exception as e:
                # If all else fails, return a response with no answers (NXDOMAIN)
                response.header.rcode = 3  # NXDOMAIN
                self.socket.sendto(response.pack(), addr)
                self.stats['errors'] += 1
                
        except Exception as e:
            logger.error(f"DNS request handling error: {e}")
            self.stats['errors'] += 1
            # Try to send back an error response
            try:
                error_response = DNSRecord.parse(data)
                error_response.header.rcode = 2  # Server error
                self.socket.sendto(error_response.pack(), addr)
            except:
                pass
    
    def stop(self):
        """Stop the DNS server"""
        self.running = False
        if self.socket:
            try:
                self.socket.close()
            except:
                pass
        logger.info(f"DNS Identity Server stopped for IP {self.carrier_ip}")
        return True
    
    def get_stats(self):
        """Get DNS server statistics"""
        uptime = time.time() - self.stats['start_time']
        return {
            'ip': self.carrier_ip,
            'port': self.port,
            'carrier_dns': self.carrier_dns,
            'uptime': uptime,
            'requests': self.stats['requests'],
            'requests_per_minute': (self.stats['requests'] / uptime * 60) if uptime > 0 else 0,
            'cache_hits': self.stats['cache_hits'],
            'carrier_lookups': self.stats['carrier_lookups'],
            'fallbacks': self.stats['fallbacks'],
            'errors': self.stats['errors'],
            'cache_size': len(self.cache)
        }


# New Ultra-Aggressive IP Enforcer
class AggressiveIPEnforcer:
    """Forces browser sessions to use exactly the IP detected during collection - Ultra Aggressive Version"""
    
    def __init__(self, target_ip):
        self.target_ip = target_ip
        self.original_headers = None
        self.is_active = False
        
    def install_in_browser(self, driver):
        """Install IP forcing system into browser session with enhanced CDP header injection"""
        
        # Store original headers for comparison
        try:
            self.original_headers = self.get_browser_headers(driver)
        except Exception as e:
            logger.debug(f"Error getting original headers: {e}")
        
        # Break the process into stages and handle each separately
        stages_completed = 0
        
        # Stage 1: First use CDP to directly set headers at browser level
        try:
            driver.execute_cdp_cmd('Network.enable', {})
            stages_completed += 1
            
            driver.execute_cdp_cmd('Network.setExtraHTTPHeaders', {
                "headers": {
                    "X-Forwarded-For": self.target_ip,
                    "CF-Connecting-IP": self.target_ip,
                    "X-Real-IP": self.target_ip,
                    "True-Client-IP": self.target_ip,
                    "X-Client-IP": self.target_ip,
                    "X-T-Mobile-IP": self.target_ip,
                    "X-Carrier-IP": self.target_ip,
                    "Mobile-Gateway": self.target_ip,
                    "X-Mobile-IP": self.target_ip,
                    "Fastly-Client-IP": self.target_ip,
                    "X-Forwarded": self.target_ip,
                    "Forwarded-For": self.target_ip,
                    "X-Coming-From": self.target_ip,
                    "Coming-From": self.target_ip
                }
            })
            stages_completed += 1
            logger.info(f"CDP headers successfully set for {self.target_ip}")
        except Exception as e:
