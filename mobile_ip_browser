# Windows-specific network routing functions
def get_interface_by_ip(ip_address):
    """Find network interface that has the specified IP address"""
    if not sys.platform == 'win32':
        return None
        
    try:
        for interface, addrs in psutil.net_if_addrs().items():
            for addr in addrs:
                if addr.family == socket.AF_INET and addr.address == ip_address:
                    return interface
    except Exception as e:
        logger.error(f"Error finding interface for IP {ip_address}: {e}")
    return None

def get_interface_index(interface_name):
    """Get the interface index for a network interface name"""
    if not sys.platform == 'win32' or not WINDOWS_ROUTING_AVAILABLE:
        return None
        
    try:
        # Get interface details from netsh
        output = subprocess.check_output(
            ["netsh", "interface", "ipv4", "show", "interfaces"], 
            text=True
        )
        
        for line in output.splitlines():
            if interface_name in line:
                parts = line.split()
                if len(parts) >= 2 and parts[0].isdigit():
                    return int(parts[0])
    except Exception as e:
        logger.error(f"Error getting interface index for {interface_name}: {e}")
    return None
def create_browser_with_retries(options, uc_params, max_retries=3, delay_between_retries=2):
    """Create a Chrome browser with multiple retry attempts if it crashes"""
    for attempt in range(1, max_retries + 1):
        try:
            logger.info(f"Browser creation attempt {attempt} of {max_retries}")
            driver = uc.Chrome(options=options, **uc_params)
            driver.set_page_load_timeout(30)
            # Test if browser is responsive
            driver.get("about:blank")
            time.sleep(1)
            title = driver.title  # This will raise an exception if browser crashed
            logger.info(f"Browser successfully created on attempt {attempt}")
            return driver
        except Exception as e:
            logger.warning(f"Browser creation failed on attempt {attempt}: {e}")
            try:
                # Try to clean up failed browser instance
                if 'driver' in locals() and driver:
                    driver.quit()
            except:
                pass
            
            if attempt < max_retries:
                # Add random jitter to avoid timing issues
                wait_time = delay_between_retries + random.uniform(0, 2)
                logger.info(f"Waiting {wait_time:.1f} seconds before retry...")
                time.sleep(wait_time)
            else:
                logger.error(f"Failed to create browser after {max_retries} attempts")
                raise
    return None
def add_route_to_interface(destination, interface_index, gateway, metric=5):
    """Add a route to a specific interface with WinAPI (more reliable than netsh)"""
    if not sys.platform == 'win32' or not WINDOWS_ROUTING_AVAILABLE:
        logger.warning("Route modification only supported on Windows")
        return False
        
    try:
        # Convert IP strings to network byte order
        dest_ip = socket.inet_aton(destination.split('/')[0])
        dest_ip = struct.unpack("!L", dest_ip)[0]
        
        gateway_ip = socket.inet_aton(gateway)
        gateway_ip = struct.unpack("!L", gateway_ip)[0]
        
        # Calculate mask from CIDR
        if '/' in destination:
            cidr = int(destination.split('/')[1])
            mask = (0xFFFFFFFF << (32 - cidr)) & 0xFFFFFFFF
        else:
            mask = 0xFFFFFFFF  # 255.255.255.255
            
        mask_bytes = struct.pack("!L", mask)
        mask = struct.unpack("!L", mask_bytes)[0]
        
        # Create the route entry
        route_entry = MIB_IPFORWARDROW()
        route_entry.dwForwardDest = dest_ip
        route_entry.dwForwardMask = mask
        route_entry.dwForwardPolicy = 0
        route_entry.dwForwardNextHop = gateway_ip
        route_entry.dwForwardIfIndex = interface_index
        route_entry.dwForwardType = 4  # MIB_IPROUTE_TYPE_INDIRECT
        route_entry.dwForwardProto = 3  # MIB_IPPROTO_NETMGMT
        route_entry.dwForwardAge = 0
        route_entry.dwForwardNextHopAS = 0
        route_entry.dwForwardMetric1 = metric
        route_entry.dwForwardMetric2 = -1
        route_entry.dwForwardMetric3 = -1
        route_entry.dwForwardMetric4 = -1
        route_entry.dwForwardMetric5 = -1
        
        # Add the route
        result = CreateIpForwardEntry(ctypes.byref(route_entry))
        if result == 0:
            logger.info(f"Successfully added route to {destination} via {gateway} on interface {interface_index}")
            return route_entry
        else:
            logger.error(f"Failed to add route. Error code: {result}")
            return False
    except Exception as e:
        logger.error(f"Error adding route: {e}")
        import traceback
        logger.error(traceback.format_exc())
        return False

