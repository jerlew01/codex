# Custom HTTP Proxy Handler with improved IP identity preservation
class IPIdentityProxyHandler(BaseHTTPRequestHandler):
    protocol_version = 'HTTP/1.1'
    
    def do_GET(self):
        self.handle_request()
        
    def do_POST(self):
        self.handle_request()
        
    def do_HEAD(self):
        self.handle_request()
    
    def handle_request(self):
        identity_ip = self.server.identity_ip
        
        # Update request count
        if hasattr(self.server, 'traffic_stats'):
            self.server.traffic_stats['requests'] += 1
        
        try:
            # Parse the request URL
            url = self.path
            if not url.startswith('http'):
                scheme = 'https' if self.headers.get('Host', '').endswith(':443') else 'http'
                url = f"{scheme}://{self.headers.get('Host', '')}{url}"
            
            # Create a new request
            req = urllib.request.Request(url)
            
            # Set the request method to match the original
            req.method = self.command
            
            # Copy all headers from the original request
            for header, value in self.headers.items():
                if header.lower() not in ['host', 'connection', 'proxy-connection']:
                    req.add_header(header, value)
            
            # Add the identity headers (expanded set)
            req.add_header('X-Forwarded-For', identity_ip)
            req.add_header('X-Client-IP', identity_ip)
            req.add_header('X-Real-IP', identity_ip)
            req.add_header('CF-Connecting-IP', identity_ip)
            req.add_header('True-Client-IP', identity_ip)
            req.add_header('X-T-Mobile-IP', identity_ip)
            req.add_header('X-Carrier-IP', identity_ip)
            req.add_header('Mobile-Gateway', identity_ip)
            req.add_header('X-Mobile-IP', identity_ip)
            req.add_header('Fastly-Client-IP', identity_ip)
            req.add_header('X-Forwarded', identity_ip)
            req.add_header('Forwarded-For', identity_ip)
            req.add_header('X-Coming-From', identity_ip)
            req.add_header('Coming-From', identity_ip)
            
            # Read request body for POST requests
            content_length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(content_length) if content_length > 0 else None
            
            # Send the request to the server
            ctx = ssl.create_default_context()
            ctx.check_hostname = False
            ctx.verify_mode = ssl.CERT_NONE
            
            # Create a socket bound to the tethering interface if available
            if hasattr(self.server, 'interface_ip') and self.server.interface_ip:
                # Create a custom opener that binds to our interface
                class BoundHTTPHandler(urllib.request.HTTPHandler):
                    def http_open(self, req):
                        return self.do_open(self.create_bound_connection, req)
                
                class BoundHTTPSHandler(urllib.request.HTTPSHandler):
                    def https_open(self, req):
                        return self.do_open(self.create_bound_connection, req, context=ctx)
                
                def create_bound_connection(self, host, timeout=10):
                    # Create a socket bound to our interface
                    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                    sock.bind((self.server.interface_ip, 0))
                    sock.connect((host, 443 if isinstance(self, BoundHTTPSHandler) else 80))
                    return sock
                
                # Add the bound connection method to both handlers
                BoundHTTPHandler.create_bound_connection = create_bound_connection
                BoundHTTPSHandler.create_bound_connection = create_bound_connection
                
                # Create an opener using these custom handlers
                opener = urllib.request.build_opener(BoundHTTPHandler, BoundHTTPSHandler)
                response = opener.open(req, data=body, timeout=10)
            else:
                # Standard request without interface binding
                response = urllib.request.urlopen(req, data=body, timeout=10, context=ctx)
            
            # Get response body
            response_body = response.read()
            if hasattr(self.server, 'traffic_stats'):
                self.server.traffic_stats['bytes_received'] += len(response_body)
            
            # Send the response back to the client
            self.send_response(response.status)
            
            # Copy all headers from the response
            for header, value in response.getheaders():
                if header.lower() not in ['connection', 'transfer-encoding']:
                    self.send_header(header, value)
            
            # Add our custom identity headers
            self.send_header('X-Identity-IP', identity_ip)
            self.end_headers()
            
            # Send the response body
            self.wfile.write(response_body)
            if hasattr(self.server, 'traffic_stats'):
                self.server.traffic_stats['bytes_sent'] += len(response_body)
            
        except Exception as e:
            if hasattr(self.server, 'traffic_stats'):
                self.server.traffic_stats['errors'] += 1
                
            logger.error(f"Proxy error ({url}): {e}")
            self.send_error(500, f"Proxy Error: {str(e)}")
    
    def do_CONNECT(self):
        host_port = self.path.split(':')
        host = host_port[0]
        
        # Safer port handling
        try:
            port = int(host_port[1]) if len(host_port) > 1 else 443
        except ValueError:
            port = 443  # Default to HTTPS port if we can't parse
            
        self.send_response(200, 'Connection Established')
        self.send_header('Connection', 'close')
        self.end_headers()
        
        try:
            # If we have a specific interface to bind to, use it
            if hasattr(self.server, 'interface_ip') and self.server.interface_ip:
                remote = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                remote.bind((self.server.interface_ip, 0))
            else:
                remote = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
                
            remote.settimeout(10)  # 10 second timeout
            remote.connect((host, port))
            
            # IMPORTANT: Set TCP_NODELAY to improve performance
            remote.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
            self.connection.setsockopt(socket.IPPROTO_TCP, socket.TCP_NODELAY, 1)
            
            # Create a special socket timeout context for the CONNECT tunnel
            remote.settimeout(60)  # Longer timeout for established connections
            self.connection.settimeout(60)
            
            # Forward data in both directions
            forward_thread = threading.Thread(
                target=self.forward_data, 
                args=(self.connection, remote, "client->server"),
                daemon=True
            )
            forward_thread.start()
            
            # Forward data from remote to client
            self.forward_data(remote, self.connection, "server->client")
            
        except Exception as e:
            if hasattr(self.server, 'traffic_stats'):
                self.server.traffic_stats['errors'] += 1
                
            logger.error(f"HTTPS proxy error ({host}:{port}): {e}")
            # Connection is already established, can't send HTTP error
            
    def forward_data(self, source, destination, direction):
        try:
            source_name = f"{source.getsockname()}"
            dest_name = f"{destination.getsockname()}"
            
            source.setblocking(0)
            
            # Create a buffer for data chunks
            buffer_size = 16384  # Larger buffer for better performance
            
            while True:
                try:
                    data = source.recv(buffer_size)
                    if not data:
                        break
                        
                    # Special case for identity IP injection in HTTPS tunnels
                    # If this is a TLS Client Hello or HTTP request, we might want to 
                    # modify it to insert our identity. But this requires SSL termination
                    # which is complex and beyond this proxy's current scope.
                    
                    # Send data to destination
                    destination.sendall(data)
                    
                    # Update traffic stats
                    if hasattr(self.server, 'traffic_stats'):
                        if direction == "client->server":
                            self.server.traffic_stats['bytes_received'] += len(data)
                        else:
                            self.server.traffic_stats['bytes_sent'] += len(data)
                            
                except socket.error as e:
                    if e.errno == socket.EAGAIN or e.errno == socket.EWOULDBLOCK:
                        # No data available, sleep briefly
                        time.sleep(0.01)
                        continue
                    else:
                        # Real error occurred
                        break
                        
        except Exception as e:
            # Just log at debug level to avoid filling logs
            logger.debug(f"Connection forwarding error: {e}")
        finally:
            try:
                source.close()
                destination.close()
            except:
                pass
    
    def log_message(self, format, *args):
