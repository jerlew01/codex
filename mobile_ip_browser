# Launch a browser with ForceBindIP to bind it to a specific interface
def launch_with_forcebindip(chrome_path, ip_address, arguments=None):
    """Launch Chrome using ForceBindIP to bind it to a specific IP/interface"""
    if not HAS_FORCEBINDIP:
        logger.error("ForceBindIP not found. Cannot force interface binding.")
        return None
        
    try:
        command = [FORCEBINDIP_PATH, ip_address, chrome_path]
        if arguments:
            command.extend(arguments)
            
        logger.info(f"Launching Chrome with ForceBindIP: {' '.join(command)}")
        process = subprocess.Popen(command, stdout=subprocess.PIPE, stderr=subprocess.PIPE)
        
        # Wait a moment for the process to start
        time.sleep(2)
        
        # Check if process is still running
        if process.poll() is None:
            logger.info("Chrome successfully launched with ForceBindIP")
            return process
        else:
            stdout, stderr = process.communicate()
            logger.error(f"ForceBindIP failed. Return code: {process.returncode}")
            logger.error(f"STDOUT: {stdout.decode('utf-8', errors='ignore')}")
            logger.error(f"STDERR: {stderr.decode('utf-8', errors='ignore')}")
            return None
    except Exception as e:
        logger.error(f"Error launching with ForceBindIP: {e}")
        return None

