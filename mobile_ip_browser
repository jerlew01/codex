def handle_ip_change(new_ip):
    """Create a new session when a new IP is detected"""
    global known_ips, AUTO_CREATE_SESSIONS
    
    # First, check if automatic session creation is enabled
    if not AUTO_CREATE_SESSIONS:
        logger.info(f"IP change detected ({new_ip}), but automatic session creation is disabled")
        # Still add to known IPs
        known_ips.add(new_ip)
        return None
    
    logger.info(f"Handling IP change - New IP: {new_ip}")
    
    # Check if we already have a session for this IP
    for session in active_sessions.values():
        if session['ip'] == new_ip:
            logger.info(f"Session already exists for IP {new_ip}")
            return None
    
    # Create a new session for this IP
    try:
        session_id = create_browser_session(new_ip)
        if session_id:
            logger.info(f"Created new session #{session_id} for IP {new_ip}")
            return session_id
        else:
            logger.error(f"Failed to create session for IP {new_ip}")
            return None
    except Exception as e:
        logger.error(f"Error creating session for new IP {new_ip}: {e}")
        return None


def switch_to_wifi(wifi_name=None, wifi_password=None):
    """Switch from tethered connection to WiFi"""
    global known_ips
    
    print("\n==== SWITCHING TO WIFI ====")
    print("This will disconnect your tethered connection and connect to WiFi.")
    print("Your browser sessions will continue to use the collected mobile IPs.")
    
    if not wifi_name:
        wifi_name = input("Enter WiFi network name: ")
    if not wifi_password:
        wifi_password = input("Enter WiFi password: ")
    
    print(f"Attempting to connect to WiFi network '{wifi_name}'...")
    
    # First, check if we have routes set up for verification domains
    have_verification_routes = False
    for session in active_sessions.values():
        if 'routes' in session and session['routes']:
            have_verification_routes = True
            break
    
    if not have_verification_routes:
        logger.warning("No verification routes set up. This may cause identity loss after switching to WiFi.")
        proceed = input("Proceed without verification routes? (y/n): ").lower()
        if proceed != 'y':
            print("Canceled WiFi switch. Try restarting with fewer sessions.")
            return False
    
    # Add more verification routes before switching
    tether_interface, tether_ip, tether_gateway = get_tethering_interface_info()
    if tether_interface and tether_gateway and WINDOWS_ROUTING_AVAILABLE:
        print("Setting up additional verification routes before WiFi switch...")
        
        try:
            interface_index = get_interface_index(tether_interface)
            if interface_index:
                # Add specific routes for important domains
                verification_sites = [
                    "ipinfo.io", 
                    "api.ipify.org", 
                    "ifconfig.me", 
                    "icanhazip.com", 
                    "checkip.amazonaws.com",
                    "twitch.tv",
                    "youtube.com",
                    "google.com"
                ]
                
                for session_id in list(active_sessions.keys()):
                    session = active_sessions[session_id]
                    if 'routes' not in session:
                        session['routes'] = []
                    
                    for site in verification_sites:
                        try:
                            site_ip = socket.gethostbyname(site)
                            logger.info(f"Adding verification route for {site} ({site_ip})")
                            route = add_route_to_interface(
                                f"{site_ip}/32", 
                                interface_index, 
                                tether_gateway, 
                                metric=1
                            )
                            if route:
                                session['routes'].append(route)
                                print(f"Added route for {site} ({site_ip})")
                        except Exception as e:
                            logger.warning(f"Failed to add route for {site}: {e}")
        except Exception as e:
            logger.warning(f"Failed to setup additional verification routes: {e}")
    
    if WIFI_CONTROL_AVAILABLE:
        try:
            # Initialize WiFi manager
            wifi_manager = pywifi.PyWiFi()
            iface = wifi_manager.interfaces()[0]  # Use first wireless interface
            
            # Disconnect if already connected
            if iface.status() in [const.IFACE_CONNECTED, const.IFACE_CONNECTING]:
                iface.disconnect()
                time.sleep(1)
                print("Disconnected from current network.")
            
            # Create profile
            profile = pywifi.Profile()
            profile.ssid = wifi_name
            profile.auth = const.AUTH_ALG_OPEN
            profile.akm.append(const.AKM_TYPE_WPA2PSK)
            profile.cipher = const.CIPHER_TYPE_CCMP
            profile.key = wifi_password
            
            # Add profile
            print("Configuring WiFi connection...")
            temp_profile = iface.add_network_profile(profile)
            
            # Connect
            print("Initiating connection...")
            iface.connect(temp_profile)
            
            # Wait for connection
            print("Connecting to WiFi...", end="", flush=True)
            for _ in range(15):  # Wait up to 15 seconds
                print(".", end="", flush=True)
                if iface.status() == const.IFACE_CONNECTED:
                    print("\nConnected to WiFi successfully!")
                    
                    # Wait for network to stabilize
                    print("Waiting for network to stabilize...")
                    time.sleep(5)
                    
                    # Check if we have internet access
                    try:
                        new_ip = get_current_ip()
                        print(f"New network IP: {new_ip}")
                        # Update known IPs
                        if new_ip:
                            known_ips.add(new_ip)
                        
                        # Refresh all sessions to maintain identity
                        print("Reinforcing mobile IP identity in all sessions...")
                        handle_network_change()
                        
                        # Verify all sessions
                        print("\nVerifying all sessions after WiFi switch:")
                        all_verified = True
                        for session_id in list(active_sessions.keys()):
                            if verify_session_identity(session_id):
                                print(f"  Session #{session_id}: ✓ Verified")
                            else:
                                print(f"  Session #{session_id}: ✗ Failed verification")
                                all_verified = False
                        
                        if all_verified:
                            print("\n[SUCCESS] All sessions maintained mobile IP identity")
                        else:
                            print("\n[WARNING] Some sessions failed to maintain mobile IP identity")
                            
                        return True
                    except Exception as e:
                        print(f"Connected to WiFi but couldn't verify internet access: {e}")
                        return True
                time.sleep(1)
            
            print("\nFailed to connect to WiFi within timeout period.")
            return False
            
        except Exception as e:
            print(f"Error switching to WiFi: {e}")
            print("You may need to connect to WiFi manually.")
            manual_connect = input("Would you like to connect manually? (y/n): ").lower()
            if manual_connect == 'y':
                input("Please connect to WiFi manually, then press Enter when done...")
                time.sleep(5)  # Allow connection to stabilize
                
                # Refresh all sessions to maintain identity
                print("Reinforcing mobile IP identity in all sessions...")
                handle_network_change()
                
                # Verify all sessions
                print("\nVerifying all sessions after manual WiFi switch:")
                all_verified = True
                for session_id in list(active_sessions.keys()):
                    if verify_session_identity(session_id):
                        print(f"  Session #{session_id}: ✓ Verified")
                    else:
                        print(f"  Session #{session_id}: ✗ Failed verification")
                        all_verified = False
                
                if all_verified:
                    print("\n[SUCCESS] All sessions maintained mobile IP identity")
                else:
                    print("\n[WARNING] Some sessions failed to maintain mobile IP identity")
                
                new_ip = get_current_ip()
                if new_ip:
                    print(f"Detected IP after manual connection: {new_ip}")
                    known_ips.add(new_ip)
                    return True
                else:
                    print("Could not verify connection after manual setup.")
                    return False
            return False
    else:
        print("WiFi control is not available. Please connect to WiFi manually.")
        input("Press Enter when you've connected to WiFi...")
        
        # Wait for network to stabilize
        print("Waiting for network to stabilize...")
        time.sleep(5)
        
        # Refresh all sessions to maintain identity
        print("Reinforcing mobile IP identity in all sessions...")
        handle_network_change()
        
        # Verify all sessions
        print("\nVerifying all sessions after manual WiFi switch:")
        all_verified = True
        for session_id in list(active_sessions.keys()):
            if verify_session_identity(session_id):
                print(f"  Session #{session_id}: ✓ Verified")
            else:
                print(f"  Session #{session_id}: ✗ Failed verification")
                all_verified = False
        
        if all_verified:
            print("\n[SUCCESS] All sessions maintained mobile IP identity")
        else:
            print("\n[WARNING] Some sessions failed to maintain mobile IP identity")
        
        # Verify connection
        try:
            new_ip = get_current_ip()
            print(f"Connected with IP: {new_ip}")
            # Update known IPs
            if new_ip:
                known_ips.add(new_ip)
            return True
        except Exception as e:
            print(f"Could not verify WiFi connection: {e}")
            return False

def track_global_stats():
    """Track statistics across all active sessions"""
    while True:
        time.sleep(120)  # Every 2 minutes
        
        with session_lock:
            if not active_sessions:
                continue
                
            logger.info("\n=== GLOBAL STATS ===")
            
            # Count sessions by verification status
            verified_count = sum(1 for s in active_sessions.values() if s.get('verified', False))
            
            # Count sessions with active spoofing
            spoofing_count = sum(1 for s in active_sessions.values() 
                               if 'spoof_thread' in s and s['spoof_thread'].is_alive())
            
            # Count sessions with active IP enforcer
            enforcer_count = sum(1 for s in active_sessions.values()
                              if 'ip_enforcer' in s and s['ip_enforcer'].is_active)
            
            # Count sessions with active DNS
            dns_count = sum(1 for s in active_sessions.values()
                         if s.get('dns_port') and s.get('dns_port') in active_dns_servers)
            
            # Count sessions with routes
            routes_count = sum(1 for s in active_sessions.values()
                            if 'routes' in s and s['routes'])
            
            # Total traffic stats
            total_requests = 0
            total_errors = 0
            total_pages = 0
            total_packets = 0
            total_packet_bytes = 0
            total_dns_requests = 0
            
            # Calculate totals
            for session_id, session in active_sessions.items():
                # Add page stats
                total_pages += session['stats']['pages_loaded']
                total_errors += session['stats']['errors']
                
                # Add proxy stats
                proxy_port = session.get('port')
                if proxy_port in active_proxies:
                    proxy = active_proxies[proxy_port]
                    if hasattr(proxy.get('server'), 'traffic_stats'):
                        stats = proxy['server'].traffic_stats
                        total_requests += stats.get('requests', 0)
                
                # Add DNS stats
                dns_port = session.get('dns_port')
                if dns_port in active_dns_servers:
                    dns_server = active_dns_servers[dns_port]['server']
                    if hasattr(dns_server, 'get_stats'):
                        stats = dns_server.get_stats()
                        total_dns_requests += stats.get('requests', 0)
                
                # Add packet stats
                if 'spoof_manager' in session:
                    sm = session['spoof_manager']
                    stats = sm.traffic_stats
                    total_packets += stats.get('packets_sent', 0)
                    total_packet_bytes += stats.get('bytes_sent', 0)
            
            # Log the summary
            logger.info(f"Sessions: {len(active_sessions)} total, {verified_count} verified")
            logger.info(f"IP Enforcement: {enforcer_count} sessions with active IP enforcing")
            logger.info(f"DNS Identity: {dns_count} sessions with DNS identity preservation")
            logger.info(f"Packet Spoofing: {spoofing_count} sessions with active spoofing")
            logger.info(f"Custom Routes: {routes_count} sessions with custom routing")
            logger.info(f"Pages Loaded: {total_pages}")
            logger.info(f"Proxy Requests: {total_requests}")
            logger.info(f"DNS Requests: {total_dns_requests}")
            logger.info(f"Errors: {total_errors}")
            logger.info(f"Packets Sent: {total_packets}")
            logger.info(f"Packet Data: {total_packet_bytes/1024:.2f} KB")
            logger.info("=====================\n")

