                        print(f"  IP: {info['ip_identity']}")
                        print(f"  Reported IP: {info['reported_ip']}")
                        print(f"  Verified: {info['verified']}")
                        print(f"  URL: {info['current_url']}")
                        print(f"  Age: {info['age_seconds']:.1f} seconds")
                        print(f"  Last verified: {time.time() - active_sessions[session_id].get('last_verified', 0):.1f} seconds ago")
                        print(f"  Proxy: Port {info['proxy_port']}")
                        print(f"  DNS: {'Active on port ' + str(info['dns_port']) if info['dns_active'] else 'Inactive'}")
                        print(f"  IP Enforcer: {'Active' if info['ip_enforcer'] else 'Inactive'}")
                        print(f"  ForceBindIP: {'Active' if info['forcebindip_active'] else 'Inactive'}")
                        print(f"  Custom Routes: {info['routes_added']}")
                        print(f"  Tethering Interface: {info['tether_interface']}")
                        
                        if 'traffic_stats' in info:
                            ts = info['traffic_stats']
                            print(f"  Traffic: {ts.get('requests', 0)} requests, {ts.get('errors', 0)} errors")
                    else:
                        print(f"Session #{session_id} not found")
                else:
                    print("Usage: info [session_id]")
            
            elif cmd == 'stats':
                with session_lock:
                    print("\n=== TRAFFIC STATISTICS ===")
                    
                    # Proxy stats
                    if active_proxies:
                        print("Proxy Statistics:")
                        for port, proxy_info in active_proxies.items():
                            server = proxy_info.get('server')
                            ip = proxy_info.get('ip', 'Unknown')
                            
                            if hasattr(server, 'traffic_stats'):
                                stats = server.traffic_stats
                                print(f"  Proxy {port} (IP: {ip}):")
                                print(f"    Requests: {stats.get('requests', 0)}")
                                print(f"    Bytes Sent: {stats.get('bytes_sent', 0)/1024:.1f} KB")
                                print(f"    Bytes Received: {stats.get('bytes_received', 0)/1024:.1f} KB")
                                print(f"    Errors: {stats.get('errors', 0)}")
                    else:
                        print("No active proxies")
                    
                    # DNS stats
                    if active_dns_servers:
                        print("\nDNS Server Statistics:")
                        for port, dns_info in active_dns_servers.items():
                            server = dns_info.get('server')
                            ip = dns_info.get('ip', 'Unknown')
                            
                            if hasattr(server, 'get_stats'):
                                stats = server.get_stats()
                                print(f"  DNS {port} (IP: {ip}):")
                                print(f"    Requests: {stats.get('requests', 0)}")
                                print(f"    Cache Hits: {stats.get('cache_hits', 0)}")
                                print(f"    Carrier Lookups: {stats.get('carrier_lookups', 0)}")
                                print(f"    Fallbacks: {stats.get('fallbacks', 0)}")
                                print(f"    Errors: {stats.get('errors', 0)}")
                    else:
                        print("\nNo active DNS servers")
                        
                    # Routes stats
                    routes_count = 0
                    for session in active_sessions.values():
                        if 'routes' in session:
                            routes_count += len(session['routes'])
                    
                    if routes_count > 0:
                        print(f"\nActive Custom Routes: {routes_count}")
            
            elif cmd == 'ips':
                with session_lock:
                    print("\n=== KNOWN IP ADDRESSES ===")
                    print(f"Total known IPs: {len(known_ips)}")
                    
                    if known_ips:
                        # Group by usage
                        active_ips = {session['ip'] for session in active_sessions.values()}
                        inactive_ips = known_ips - active_ips
                        
                        if active_ips:
                            print("\nIPs with active sessions:")
                            for ip in sorted(active_ips):
                                # Count sessions using this IP
                                count = sum(1 for s in active_sessions.values() if s['ip'] == ip)
                                print(f"  {ip} ({count} sessions)")
                        
                        if inactive_ips:
                            print("\nKnown IPs without active sessions:")
                            for ip in sorted(inactive_ips):
                                # Check if it was dropped
                                reason = dropped_sessions.get(ip, "Not used")
                                print(f"  {ip} ({reason})")
                    else:
                        print("No IPs collected yet")
            
            elif cmd == 'refresh':
                with session_lock:
                    # Find failed sessions
                    failed_sessions = [sid for sid, session in active_sessions.items() 
                                     if not session.get('verified', False)]
                    
                    if not failed_sessions:
                        print("No failed sessions to refresh")
                    else:
                        print(f"Found {len(failed_sessions)} unverified sessions. Recreating...")
                        
                        for sid in failed_sessions:
                            # Get the session IP and current URL
                            ip = active_sessions[sid]['ip']
                            url = active_sessions[sid].get('current_url', target_url)
                            
                            # Close the session
                            close_session(sid)
                            
                            # Try to create a new session
                            new_sid = create_browser_session(ip, url, use_incognito)
                            if new_sid:
                                print(f"Recreated session #{sid} as #{new_sid} for IP {ip}")
                            else:
                                print(f"Failed to recreate session for IP {ip}")
            
            elif cmd == 'wifi':
                # Switch to WiFi while maintaining mobile identities
                if len(active_sessions) == 0:
                    print("No active sessions to maintain. Please create sessions first.")
                else:
                    switch_to_wifi()
            
            elif cmd == 'verify':
                # Verify identity of all sessions
                with session_lock:
                    if not active_sessions:
                        print("No active sessions to verify")
                    else:
                        print("\nVerifying all sessions:")
                        all_verified = True
                        for session_id in list(active_sessions.keys()):
                            print(f"Verifying session #{session_id}...")
                            # Reinforce the identity first
                            session = active_sessions[session_id]
                            if 'ip_enforcer' in session:
                                try:
                                    session['ip_enforcer'].install_in_browser(session['driver'])
                                    print(f"  Re-applied IP enforcement")
                                except Exception as e:
                                    print(f"  Error re-applying IP enforcement: {e}")
                            
                            # Now verify
                            if verify_session_identity(session_id):
                                print(f"  Session #{session_id}: ✓ Verified")
                            else:
                                print(f"  Session #{session_id}: ✗ Failed verification")
                                all_verified = False
                        
                        if all_verified:
                            print("\n[SUCCESS] All sessions verified successfully")
                        else:
                            print("\n[WARNING] Some sessions failed verification")
            
            elif cmd.startswith('screen'):
                parts = cmd.split(maxsplit=1)
                if len(parts) > 1 and parts[1].isdigit():
                    session_id = int(parts[1])
                    if session_id in active_sessions:
                        screenshot_path = take_screenshot(session_id)
                        if screenshot_path:
                            print(f"Screenshot saved to: {screenshot_path}")
                        else:
                            print("Failed to take screenshot")
                    else:
                        print(f"Session #{session_id} not found")
                else:
                    print("Usage: screen [session_id]")
            
            elif cmd.startswith('visit'):
                parts = cmd.split(maxsplit=2)
                if len(parts) > 2 and parts[1].isdigit():
                    session_id = int(parts[1])
                    url = parts[2]
                    if session_id in active_sessions:
                        if visit_url(session_id, url):
                            print(f"Navigated session #{session_id} to {url}")
                        else:
                            print(f"Failed to navigate to {url}")
                    else:
                        print(f"Session #{session_id} not found")
                else:
                    print("Usage: visit [session_id] [url]")
                    
            elif cmd == 'routes':
                # Display all custom routes
                with session_lock:
                    print("\n=== CUSTOM ROUTES ===")
                    routes_count = 0
                    for session_id, session in active_sessions.items():
                        if 'routes' in session and session['routes']:
                            routes_count += len(session['routes'])
                            print(f"Session #{session_id}: {len(session['routes'])} routes")
                    
                    if routes_count == 0:
                        print("No custom routes active")
                    else:
                        print(f"Total custom routes: {routes_count}")
            
            elif cmd == 'force':
                # Force route update for all sessions
                with session_lock:
                    print("\nForcing route updates for all sessions...")
                    
                    # Get tethering interface info
                    tether_interface, tether_ip, tether_gateway = get_tethering_interface_info()
                    if not tether_interface or not tether_gateway:
                        print("Could not detect tethering interface or gateway. Cannot update routes.")
                    else:
                        interface_index = get_interface_index(tether_interface)
                        if not interface_index:
                            print(f"Could not get index for interface {tether_interface}")
                        else:
                            # Add specific routes for important domains
                            verification_sites = [
                                "ipinfo.io", 
                                "api.ipify.org", 
                                "ifconfig.me", 
                                "icanhazip.com", 
                                "checkip.amazonaws.com"
                            ]
                            
                            for session_id in list(active_sessions.keys()):
                                session = active_sessions[session_id]
                                # First remove any existing routes
                                if 'routes' in session:
                                    for route in session['routes']:
                                        try:
                                            delete_route(route)
                                        except:
                                            pass
                                    session['routes'] = []
                                else:
                                    session['routes'] = []
                                
                                # Now add new routes
                                success_count = 0
                                for site in verification_sites:
                                    try:
                                        site_ip = socket.gethostbyname(site)
                                        route = add_route_to_interface(
                                            f"{site_ip}/32", 
                                            interface_index, 
                                            tether_gateway, 
                                            metric=1
                                        )
                                        if route:
                                            session['routes'].append(route)
                                            success_count += 1
                                    except Exception as e:
                                        print(f"Error adding route for {site}: {e}")
                                
                                print(f"Session #{session_id}: Added {success_count} new routes")
            
            elif cmd in ['quit', 'exit']:
                print("Exiting...")
                break
            
            else:
                print("Unknown command. Type 'help' for a list of commands.")
    
    except KeyboardInterrupt:
        print("\nInterrupted. Cleaning up...")
    
    finally:
        # Make sure to clean up all resources
        close_all_sessions()
        logger.info("IP Identity Preservation System shutdown complete")

# Entry point
if __name__ == "__main__":
    run_ip_identity_system()

