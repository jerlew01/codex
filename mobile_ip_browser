                last_verified = time.time() - session.get('last_verified', session.get('start_time', time.time()))
                
                # Check packet spoofing status
                packet_spoofing = "Active" if session.get('spoof_thread') and session.get('spoof_thread').is_alive() else "Off"
                
                # Check IP enforcer status
                ip_enforcer = "Active" if 'ip_enforcer' in session and session['ip_enforcer'].is_active else "Off"
                
                # Check DNS server status
                dns_active = "Active" if session.get('dns_port') and session.get('dns_port') in active_dns_servers else "Off"
                
                # Get traffic stats
                proxy_port = session.get('port')
                traffic_stats = "N/A"
                if proxy_port in active_proxies:
                    proxy = active_proxies[proxy_port]
                    if hasattr(proxy.get('server'), 'traffic_stats'):
                        stats = proxy['server'].traffic_stats
                        traffic_stats = f"Requests: {stats['requests']}, Errors: {stats['errors']}"
                
                status = "[PASS]" if session.get('verified', False) else "[FAIL]"
                logger.info(f"  #{session_id}: {status} Expected: {expected_ip}, Actual: {reported_ip}")
                logger.info(f"    Age: {age:.1f}s, Last verified: {last_verified:.1f}s ago")
